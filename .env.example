# ====================================
# Binance API Credentials
# ====================================
# 强烈建议:从 Binance 创建专用 API key
# 并开启 Futures 交易权限,关闭提现权限

BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here

# API 环境: prod | testnet | demo
# 强烈建议从 demo (testnet) 开始
BINANCE_API_ENV=demo

# ====================================
# 交易参数
# ====================================
# 默认交易对(单策略回测时使用)
DEFAULT_SYMBOL=BTCUSDT

# 杠杆倍数(全策略统一,20x)
LEVERAGE=20

# 保证金模式: ISOLATED | CROSSED
DEFAULT_MARGIN_TYPE=ISOLATED

# K线周期(逗号分隔,多周期)
# 量化策略通常同时用多个时间框架
KLINE_INTERVALS=3m,5m

# ====================================
# 下单金额
# ====================================
# 每单保证金 = 账户净值 × ORDER_PCT_OF_MARGIN%
# 例:净值 100, ORDER_PCT_OF_MARGIN=4 → 每单保证金 4 USDT
# 20x 杠杆下,这 4 USDT 撬动 80 USDT 名义仓位
ORDER_PCT_OF_MARGIN=4

# ====================================
# 交易品种池
# ====================================
# 池子文件路径(运行时生成,gitignored)
TRADING_PAIRS_FILE=config/trading_pairs.json

# 池子大小(交易量前 N)
TRADING_PAIRS_TOP_N=40

# 每天更新时刻(UTC,格式 HH:MM)
# 默认 00:00 UTC = 北京时间 08:00
PAIR_UPDATE_TIME_UTC=00:00

# 启动时是否自动刷新池子
PAIR_AUTO_UPDATE_ON_START=true

# ====================================
# 风控
# ====================================
MAX_POSITION_SIZE_PCT=4     # 单币种最大持仓保证金占账户净值
MAX_DAILY_LOSS_PCT=10
STOP_LOSS_PCT=2
MAX_LEVERAGE=20

# 币种池之外要禁用的(逗号分隔,可选)
BLACKLIST_SYMBOLS=

# CLI profile 名称
BINANCE_PROFILE=default
